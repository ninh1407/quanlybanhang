
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// User & Auth (Keep existing but align if needed)
model User {
  id                 String   @id @default(uuid())
  username           String   @unique
  password           String?
  fullName           String   @map("full_name")
  role               Role
  active             Boolean  @default(true)
  allowedLocationIds String[] @map("allowed_location_ids") // Stored as array of strings
  scope              String? // 'all' | 'region' | 'location'
  region             String?
  createdAt          DateTime @default(now()) @map("created_at")

  // Relations
  ordersCreated        Order[]        @relation("OrderCreator")
  stockVouchersCreated StockVoucher[] @relation("StockVoucherCreator")

  @@map("users")
}

enum Role {
  admin
  staff
  manager
  accountant
  region_manager
  ceo
}

// 1. PRODUCT
model Product {
  id          String   @id @default(uuid())
  name        String
  categoryId  String?  @map("category_id")
  brand       String?
  description String?
  status      String   @default("active") // active, inactive, draft
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  category Category? @relation(fields: [categoryId], references: [id])
  skus     Sku[]

  @@map("products")
}

// 2. SKU (Variant)
model Sku {
  id        String   @id @default(uuid())
  productId String   @map("product_id")
  skuCode   String   @unique @map("sku_code")
  color     String?
  size      String?
  cost      Float    @default(0)
  price     Float    @default(0)
  barcode   String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  product        Product         @relation(fields: [productId], references: [id])
  inventory      Inventory[]
  orderItems     OrderItem[]
  stockMovements StockMovement[]

  @@map("product_skus")
}

// 3. CATEGORY
model Category {
  id        String   @id @default(uuid())
  name      String
  parentId  String?  @map("parent_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  parent   Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children Category[] @relation("CategoryHierarchy")
  products Product[]

  @@map("categories")
}

// 4. WAREHOUSE
model Warehouse {
  id        String   @id @default(uuid())
  code      String   @unique
  name      String
  region    String?
  lat       Float?
  lng       Float?
  address   String?
  status    String   @default("active") // active, inactive
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  inventory      Inventory[]
  stockMovements StockMovement[]
  orders         Order[] // Orders assigned to this warehouse

  @@map("warehouses")
}

// 5. INVENTORY
model Inventory {
  id          String   @id @default(uuid())
  skuId       String   @map("sku_id")
  warehouseId String   @map("warehouse_id")
  quantity    Int      @default(0)
  reserved    Int      @default(0)
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  sku       Sku       @relation(fields: [skuId], references: [id])
  warehouse Warehouse @relation(fields: [warehouseId], references: [id])

  @@unique([skuId, warehouseId])
  @@map("inventory")
}

// 6. ORDER
model Order {
  id                String          @id @default(uuid())
  orderCode         String          @unique @map("order_code")
  customerId        String?         @map("customer_id")
  warehouseId       String?         @map("warehouse_id") // Assigned Warehouse
  channel           String? // web, pos, shopee, lazada, tiktok
  status            OrderStatus     @default(draft)
  paymentStatus     PaymentStatus   @default(pending) @map("payment_status")
  fulfillmentStatus FulfillmentStatus @default(unfulfilled) @map("fulfillment_status")
  total             Float           @default(0)
  createdAt         DateTime        @default(now()) @map("created_at")
  updatedAt         DateTime        @updatedAt @map("updated_at")
  createdByUserId   String?         @map("created_by_user_id")

  // Relations
  customer  Customer?   @relation(fields: [customerId], references: [id])
  warehouse Warehouse?  @relation(fields: [warehouseId], references: [id])
  createdBy User?       @relation("OrderCreator", fields: [createdByUserId], references: [id])
  items     OrderItem[]

  @@map("orders")
}

enum OrderStatus {
  draft
  pending
  confirmed
  processing
  completed
  cancelled
  returned
}

enum PaymentStatus {
  pending
  partial
  paid
  refunded
}

enum FulfillmentStatus {
  unfulfilled
  picking
  packed
  shipped
  delivered
  returned
  failed
}

// 7. ORDER ITEMS
model OrderItem {
  id        String   @id @default(uuid())
  orderId   String   @map("order_id")
  skuId     String   @map("sku_id")
  quantity  Int
  price     Float
  total     Float
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  order Order @relation(fields: [orderId], references: [id])
  sku   Sku   @relation(fields: [skuId], references: [id])

  @@map("order_items")
}

// 8. STOCK MOVEMENT (Core)
model StockMovement {
  id            String            @id @default(uuid())
  skuId         String            @map("sku_id")
  warehouseId   String            @map("warehouse_id")
  type          StockMovementType
  quantity      Int
  referenceType String            @map("reference_type") // order, po, transfer, adjust
  referenceId   String?           @map("reference_id")
  createdAt     DateTime          @default(now()) @map("created_at")
  note          String?

  // Relations
  sku       Sku       @relation(fields: [skuId], references: [id])
  warehouse Warehouse @relation(fields: [warehouseId], references: [id])

  @@map("stock_movements")
}

enum StockMovementType {
  IN
  OUT
  TRANSFER
  ADJUST
  RESERVE
  RELEASE
}

// SUPPORTING TABLES

model Customer {
  id        String   @id @default(uuid())
  name      String
  phone     String?
  email     String?
  address   String?
  createdAt DateTime @default(now()) @map("created_at")
  orders    Order[]

  @@map("customers")
}

// Keep StockVoucher for backward compatibility or as a document wrapper for movements
model StockVoucher {
  id              String   @id @default(uuid())
  code            String   @unique
  type            String // 'in' | 'out' | 'transfer'
  status          String   @default("draft")
  fromLocationId  String?  @map("from_location_id")
  toLocationId    String?  @map("to_location_id")
  note            String?
  createdAt       DateTime @default(now()) @map("created_at")
  createdByUserId String?  @map("created_by_user_id")
  lines           Json // Array of StockVoucherLine

  createdBy User? @relation("StockVoucherCreator", fields: [createdByUserId], references: [id])

  @@map("stock_vouchers")
}
